---
interface Props {
  title: string;
  description?: string;
  href?: string;
  cta?: string;
}

const { title, description, href, cta = '查看全部' } = Astro.props;
---
<section class="paper-section">
  <div class="section-header">
    <div>
      <h2>{title}</h2>
      {description && <p>{description}</p>}
    </div>
    {href && <a class="text-link" href={href}>{cta} →</a>}
  </div>
  <slot />
</section>
